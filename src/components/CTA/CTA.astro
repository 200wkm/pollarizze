---
// CTA Section Component
---

<section class="cta-3-section section-padding">
  <div class="container">
    <div class="cta-3-section-inner">
      <div class="cta-3-title-block">
        <h2 class="cta-3-title">Take the next step toward your success!</h2>
      </div>
      <div>
        <div class="cta-3-info-block">
          <div>
            <div class="features-info-block left-block">
              <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/679a033e73e9b9e5cdb5b013_9226b85aa237bbd99f6373608051ac11_users.png" alt="Users" class="features-info-image" loading="lazy" />
              <div class="features-flex-box">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1l2.47 5.01L17 6.64l-4 3.9.94 5.51L9 13.77l-4.94 2.28.94-5.51-4-3.9 5.53-.63z" fill="#edff81"/></svg>
                <span class="features-info-text">450+ review</span>
              </div>
            </div>
          </div>
        </div>
        <p class="cta-3-desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Suspendisse varius enim in eros elementum tristique. Duis cursus, mi quis viverra ornare,</p>
        <div class="cta-3-btn-block">
          <a href="/contact/" class="btn-block btn-icon border-dark">
            <span class="btn-text-block">Explore now!</span>
            <span class="btn-icon-block">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="2"><path d="M5 10h10M12 7l3 3-3 3"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>
  <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67ac6ed6a43d7ff518e639bc_shape-dark-01.svg" alt="" aria-hidden="true" class="cta-3-ptn-image-1" loading="lazy" />
</section>

<style lang="less">
  .cta-3-section {
    background-color: var(--color-skin);
    position: relative;
    overflow: hidden;

    &.section-padding {
      padding-top: 100px;
      padding-bottom: 100px;
    }
  }

  .cta-3-section-inner {
    display: grid;
    grid-template-columns: 8fr 4fr;
    gap: 30px;
    align-items: end;
  }

  .cta-3-title {
    font-size: 78px;
    line-height: 88px;
    font-weight: 700;
    color: var(--color-dark);
    font-family: var(--font-heading);
  }

  .cta-3-info-block {
    display: grid;
    grid-template-columns: 8fr 4fr;
    gap: 60px;
    align-items: center;
    margin-bottom: 25px;
  }

  .features-info-block {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .features-info-image {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    object-fit: cover;
  }

  .features-flex-box {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .features-info-text {
    font-family: var(--font-heading);
    color: var(--color-dark);
    font-size: 18px;
    font-weight: 500;
  }

  .cta-3-desc {
    margin-bottom: 10px;
  }

  .cta-3-btn-block {
    margin-top: 30px;
  }

  .cta-3-ptn-image-1 {
    position: absolute;
    top: auto;
    right: 10px;
  }

  @media screen and (max-width: 991px) {
    .cta-3-section-inner {
      grid-template-columns: 8fr;
    }

    .cta-3-title {
      font-size: 60px;
      line-height: 70px;
    }

    .cta-3-ptn-image-1 {
      display: none;
    }

    .cta-3-section.section-padding {
      padding-top: 60px;
      padding-bottom: 60px;
    }
  }

  @media screen and (max-width: 767px) {
    .cta-3-title {
      font-size: 50px;
      line-height: 60px;
    }

    .cta-3-info-block {
      grid-template-columns: 8fr;
      gap: 30px;
    }
  }

  @media screen and (max-width: 479px) {
    .cta-3-title {
      font-size: 40px;
      line-height: 50px;
    }
  }
</style>
