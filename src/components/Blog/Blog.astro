---
// Blog Section Component
---

<section class="blog-2-section section-padding">
  <div class="container">
    <div class="blog-2-heading-wrapper">
      <div class="section-title center-text">
        <div class="section-pretitle-box">
          <svg class="pretitle-icon" width="18" height="18" viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="14" height="14" rx="2" stroke="#010127" stroke-width="1.5"/><path d="M5 6h8M5 9h6M5 12h4" stroke="#010127" stroke-width="1.5"/></svg>
          <span class="pretitle-text">Articles</span>
        </div>
        <h2 class="section-heading">Read our latest insight</h2>
      </div>
    </div>
    <div class="blog-2-section-inner">
      <div class="blog-2-wrapper">
        <div>
          <div class="blog-meta-block blog-2-meta">
            <span class="blog-category bg-grey">SaaS</span>
            <span class="blog-seprator"></span>
            <span class="blog-meta-date">January 30, 2025</span>
          </div>
          <h3 class="blog-3-title">A step-by-step guide to implementing financial SaaS solutions</h3>
        </div>
        <div>
          <div class="blog-2-btn-block">
            <a href="#" class="btn-block btn-block1 blog-btn">View details</a>
          </div>
        </div>
      </div>
      <div class="blog-2-wrapper">
        <div>
          <div class="blog-meta-block blog-2-meta">
            <span class="blog-category bg-grey">Finance</span>
            <span class="blog-seprator"></span>
            <span class="blog-meta-date">January 28, 2025</span>
          </div>
          <h3 class="blog-3-title">Top 5 ways financial SaaS helps improve cash flow management</h3>
        </div>
        <div>
          <div class="blog-2-btn-block">
            <a href="#" class="btn-block btn-block1 blog-btn">View details</a>
          </div>
        </div>
      </div>
      <div class="blog-2-wrapper">
        <div>
          <div class="blog-meta-block blog-2-meta">
            <span class="blog-category bg-grey">Business</span>
            <span class="blog-seprator"></span>
            <span class="blog-meta-date">January 25, 2025</span>
          </div>
          <h3 class="blog-3-title">Why CFOs are investing in financial SaaS platforms for strategic growth</h3>
        </div>
        <div>
          <div class="blog-2-btn-block">
            <a href="#" class="btn-block btn-block1 blog-btn">View details</a>
          </div>
        </div>
      </div>
      <div class="blog-2-wrapper">
        <div>
          <div class="blog-meta-block blog-2-meta">
            <span class="blog-category bg-grey">SaaS</span>
            <span class="blog-seprator"></span>
            <span class="blog-meta-date">January 20, 2025</span>
          </div>
          <h3 class="blog-3-title">Case studies of successful financial SaaS implementations</h3>
        </div>
        <div>
          <div class="blog-2-btn-block">
            <a href="#" class="btn-block btn-block1 blog-btn">View details</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="less">
  .blog-2-section {
    &.section-padding {
      padding-top: 100px;
      padding-bottom: 100px;
    }
  }

  .blog-2-heading-wrapper {
    text-align: center;
    margin-bottom: 30px;
  }

  .blog-2-section-inner {
    margin-top: 30px;
  }

  .blog-2-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    border-bottom: 1px solid var(--color-dark);
    padding: 35px 30px 30px;
    position: relative;
  }

  .blog-meta-block {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .blog-category {
    border-radius: 30px;
    background-color: #f5fdfe;
    border: 1px solid rgba(0, 0, 0, 0.15);
    font-family: var(--font-heading);
    color: var(--color-dark);
    padding: 3px 15px;
    display: inline-block;
    font-size: 14px;

    &.bg-grey {
      background-color: var(--color-grey);
    }
  }

  .blog-seprator {
    width: 5px;
    height: 5px;
    border-radius: 15px;
    background-color: var(--color-dark);
  }

  .blog-meta-date {
    font-family: var(--font-heading);
    color: var(--color-dark);
    font-size: 14px;
  }

  .blog-3-title {
    font-size: 26px;
    line-height: 36px;
    font-weight: 500;
    color: var(--color-dark);
    font-family: var(--font-heading);
  }

  .blog-2-btn-block {
    margin-top: 10px;
  }

  .center-text {
    text-align: center;
  }

  @media screen and (max-width: 991px) {
    .blog-2-wrapper {
      flex-flow: column;
      align-items: flex-start;
    }

    .blog-2-section.section-padding {
      padding-top: 60px;
      padding-bottom: 60px;
    }
  }

  @media screen and (max-width: 767px) {
    .blog-2-wrapper {
      padding-top: 30px;
      padding-left: 15px;
      padding-right: 15px;
    }
  }
</style>
