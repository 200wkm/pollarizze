<style lang="less">
  .features-1-section {
    &.section-padding {
      padding-top: 100px;
      padding-bottom: 100px;
    }
  }

  .features-1-section-inner {
    margin-top: 50px;
  }

  .features-1-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 30px;
  }

  .features-1-block {
    border-radius: 15px;
    background-color: var(--color-grey);
    border: 1px solid rgba(0, 0, 0, 0.15);
    display: flex;
    flex-flow: column;
    justify-content: space-between;
    padding: 40px 40px 35px;
    overflow: hidden;
  }

  .features-1-thumbnail {
    flex: none;
  }

  .features-1-image {
    width: 100%;

    &.image-shadow {
      border-radius: 10px;
      box-shadow: 0 0 16px rgba(0, 0, 0, 0.18);
    }
  }

  .features-1-content {
    margin-top: 30px;
  }

  .features-1-title {
    margin-bottom: 15px;
    font-family: var(--font-heading);
    font-size: 26px;
    line-height: 36px;
    font-weight: 500;
    color: var(--color-dark);
  }

  .features-1-desc {
    margin-bottom: 0;
  }

  .features-1-grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 30px;
  }

  .features-1-block-full {
    padding: 50px;
  }

  .features-1-wrapper {
    display: flex;
    flex-flow: column;
    gap: 30px;
  }

  .features-1-block-1 {
    display: flex;
    flex-flow: row;
    align-items: center;
    gap: 30px;
    height: 100%;
    padding-top: 50px;
    padding-bottom: 50px;
  }

  .features-1-content-1 {
    margin-top: 0;
  }

  .center-text {
    text-align: center;
  }

  @media screen and (max-width: 991px) {
    .features-1-grid {
      grid-template-columns: 1fr 1fr;
    }

    .features-1-grid-2 {
      grid-template-columns: 1fr;
    }

    .features-1-block-1 {
      flex-flow: column;
      align-items: flex-start;
      padding-top: 40px;
      padding-bottom: 35px;
    }

    .features-1-section.section-padding {
      padding-top: 60px;
      padding-bottom: 60px;
    }
  }

  @media screen and (max-width: 767px) {
    .features-1-grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 479px) {
    .features-1-block {
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
