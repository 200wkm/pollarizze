---
// Hero Section Component
---

<section class="hero-section-2">
  <div class="container">
    <div class="hero-2-content">
      <div class="hero-pretitle-block hero-pretitle-2">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M9 1l2.47 5.01L17 6.64l-4 3.9.94 5.51L9 13.77l-4.94 2.28.94-5.51-4-3.9 5.53-.63z" fill="#edff81"/></svg>
        <span class="hero-pretitle-text dark-text">Join the 37,000+ satisfied companies</span>
      </div>
      <div class="hero-2-title-block">
        <h1 class="hero-2-title">Get 5% cash</h1>
        <h1 class="hero-2-title">back on every transaction</h1>
      </div>
      <div class="hero-2-btn-block">
        <a href="/about/" class="btn-block btn-icon border-dark">
          <span class="btn-text-block">Discover more</span>
          <span class="btn-icon-block">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="2"><path d="M5 10h10M12 7l3 3-3 3"/></svg>
          </span>
        </a>
      </div>
      <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67ac6ed6a43d7ff518e639bc_shape-dark-01.svg" alt="" aria-hidden="true" class="hero-2-shape-1" loading="lazy" />
      <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67ac6ed6a43d7ff518e639bc_shape-dark-01.svg" alt="" aria-hidden="true" class="hero-2-shape-2" loading="lazy" />
    </div>
    <div class="hero-2-image-wrapper">
      <div class="hero-2-img-wrap">
        <div class="hero-2-img-block-1">
          <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/6794b1d072e9da68ab53870e_d18e02af3ccebf03ceb64c9b70427e1e_hero-02.png" alt="Hero" loading="lazy" />
        </div>
        <div class="hero-2-img-block-2">
          <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67ac36e2ac98d74c90363e7e_hero-03.png" alt="Hero" loading="lazy" />
        </div>
        <div class="hero-2-img-block-3">
          <img src="https://cdn.prod.website-files.com/6794757f3fefb734400e8445/6794b1d0db6e0feab4f50102_67ca6060ad01b5de87693f8775c42b21_hero-01.png" alt="Hero" loading="lazy" />
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="less">
  .hero-section-2 {
    background-image: url('https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67ac2c61774ae9ae33e233d9_hero-bg-img.avif');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    padding-top: 140px;
    padding-bottom: 100px;
    position: relative;
  }

  .hero-2-content {
    text-align: center;
    position: relative;
  }

  .hero-pretitle-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .hero-pretitle-text.dark-text {
    color: var(--color-dark);
    font-family: var(--font-heading);
    font-weight: 500;
  }

  .hero-2-title-block {
    position: relative;
    z-index: 1;
  }

  .hero-2-title {
    font-size: 90px;
    line-height: 100px;
    font-weight: 800;
    color: var(--color-dark);
    font-family: var(--font-heading);
  }

  .hero-2-btn-block {
    margin-top: 20px;
    position: relative;
    z-index: 1;
  }

  .hero-2-shape-1 {
    position: absolute;
    bottom: -120px;
    left: 0;
    width: auto;
  }

  .hero-2-shape-2 {
    position: absolute;
    top: 0;
    right: 60px;
    width: auto;
  }

  .hero-2-image-wrapper {
    border-radius: 50px;
    background-color: var(--color-dark);
    background-image: url('https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67a09b4e5ed3fedcaf869fde_bg-img.avif');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    display: flex;
    flex-flow: column;
    justify-content: flex-end;
    align-items: center;
    height: 500px;
    margin-top: 50px;
    padding: 40px 60px;
    overflow: hidden;
  }

  .hero-2-img-wrap {
    display: flex;
    justify-content: center;
  }

  .hero-2-img-block-1 {
    display: inline-block;
    transform: translateY(42%) rotate(-11deg);
  }

  .hero-2-img-block-2 {
    z-index: 1;
    position: relative;
    transform: translateY(30%);
  }

  .hero-2-img-block-3 {
    transform: translateY(42%) rotate(11deg);
  }

  @media screen and (max-width: 991px) {
    .hero-2-title {
      font-size: 75px;
      line-height: 85px;
    }

    .hero-2-image-wrapper {
      height: 400px;
      margin-top: 30px;
    }

    .hero-section-2 {
      padding-top: 125px;
      padding-bottom: 60px;
    }
  }

  @media screen and (max-width: 767px) {
    .hero-2-title {
      font-size: 55px;
      line-height: 65px;
    }

    .hero-2-image-wrapper {
      height: 280px;
      padding-left: 40px;
      padding-right: 40px;
    }

    .hero-2-img-block-1 {
      transform: translate(0) rotate(-11deg);
    }

    .hero-2-img-block-2 {
      display: none;
    }

    .hero-2-img-block-3 {
      transform: translate(0) rotate(11deg);
    }

    .hero-2-shape-1,
    .hero-2-shape-2 {
      display: none;
    }
  }

  @media screen and (max-width: 479px) {
    .hero-2-title {
      font-size: 50px;
      line-height: 60px;
    }

    .hero-2-image-wrapper {
      border-radius: 30px;
      height: auto;
      padding-bottom: 40px;
    }
  }
</style>
