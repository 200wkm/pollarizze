---
// Steps / How It Works Section Component
---

<section class="step-section section-padding">
  <div class="container">
    <div class="step-grid">
      <div>
        <div class="section-title">
          <div class="section-pretitle-box pretitle-dark">
            <svg class="pretitle-icon" width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="8" stroke="#fff" stroke-width="1.5"/><path d="M6 9h6M9 6v6" stroke="#fff" stroke-width="1.5"/></svg>
            <span class="pretitle-text text-white">How it works</span>
          </div>
          <h2 class="section-heading text-white">Follow these steps to unlock your potential</h2>
        </div>
        <div class="step-btn-block">
          <a href="/contact/" class="btn-block btn-icon">
            <span class="btn-text-block">Get in touch</span>
            <span class="btn-icon-block">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="2"><path d="M5 10h10M12 7l3 3-3 3"/></svg>
            </span>
          </a>
        </div>
      </div>
      <div class="step-wrapper">
        <div class="step-block">
          <div class="step-number-block"><span>01</span></div>
          <div>
            <h3 class="step-title">Sign up & create an account</h3>
            <p class="step-desc">Lorem ipsum dolor sit amet consectetur. Porta nibh elit volutpat id. Neque libero vel libero dictum dolor. In posuere viverra leo in.</p>
          </div>
        </div>
        <div class="step-block step-block-2">
          <div class="step-number-block skin-box"><span>02</span></div>
          <div>
            <h3 class="step-title">Link your payment methods</h3>
            <p class="step-desc">Porta nibh elit volutpat id. Neque libero vel libero dictum dolor. In posuere viverra volutpat maecenas suspendisse quis leo in.</p>
          </div>
        </div>
        <div class="step-block step-block-3">
          <div class="step-number-block skin2-box"><span>03</span></div>
          <div>
            <h3 class="step-title dark-title">Send or receive payments</h3>
            <p class="step-desc">Neque libero vel libero dictum dolor. In posuere viverra volutpat maecenas suspendisse quis leo in. Non cursus volutpat enim id.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="less">
  .step-section {
    background-color: var(--color-dark);
    background-image: url('https://cdn.prod.website-files.com/6794757f3fefb734400e8445/67a09c45d6ac41f374cebac4_bg-img-01.avif');
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;

    &.section-padding {
      padding-top: 100px;
      padding-bottom: 100px;
    }
  }

  .step-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
  }

  .step-btn-block {
    margin-top: 40px;
  }

  .step-wrapper {
    display: flex;
    flex-flow: column;
    gap: 20px;
  }

  .step-block {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    border-radius: 15px;
    color: rgba(255, 255, 255, 0.8);
    background-color: rgba(248, 248, 248, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.3);
    padding: 30px;
  }

  .step-block-2 {
    border-color: var(--color-skin-2);
    background-color: var(--color-skin-2);
  }

  .step-block-3 {
    background-color: var(--color-skin);
    color: rgba(1, 1, 39, 0.7);
  }

  .step-number-block {
    flex: none;
    width: 39px;
    height: 39px;
    border-radius: 30px;
    background-color: var(--color-grey);
    font-family: var(--font-heading);
    color: var(--color-dark);
    display: flex;
    justify-content: center;
    align-items: center;
    font-weight: 600;
    font-size: 14px;

    &.skin-box {
      background-color: var(--color-skin);
    }

    &.skin2-box {
      background-color: var(--color-skin-2);
      color: var(--color-white);
    }
  }

  .step-title {
    color: var(--color-white);
    margin-bottom: 15px;
    font-weight: 600;
    font-family: var(--font-heading);
    font-size: 26px;
    line-height: 36px;

    &.dark-title {
      color: var(--color-dark);
    }
  }

  .step-desc {
    margin-bottom: 0;
    font-size: 15px;
  }

  @media screen and (max-width: 991px) {
    .step-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .step-section.section-padding {
      padding-top: 60px;
      padding-bottom: 60px;
    }
  }

  @media screen and (max-width: 479px) {
    .step-block {
      flex-flow: column;
      padding-left: 20px;
      padding-right: 20px;
    }
  }
</style>
